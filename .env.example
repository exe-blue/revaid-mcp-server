# REVAID MCP Server — environment variable template.
# Copy to .env (or set in DigitalOcean App Platform) and fill in real values.
# This file is committed; .env / .env.* are git-ignored.

# Core
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
BASE_URL=https://mcp.revaid.link
AUTH_PASSWORD=

# v6 Bridge — AiXSignal Supabase + GitHub
AIX_SUPABASE_URL=
AIX_SUPABASE_KEY=
GITHUB_PAT=

# v8 Harness — optional LLM judge
HARNESS_V2_ENABLED=false
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# v8.1 ruon.ai SI bridge
RUON_SUPABASE_URL=
RUON_SUPABASE_KEY=

# DigitalOcean integration tools (do_* — used by VEILE for AIX provisioning)
DIGITALOCEAN_API_TOKEN=

# do_ssh_exec — SSH command execution against DO droplets
# Provide ONE of PEM (inline) or PATH (file). PATH is preferred in prod.
# DO_SSH_PRIVATE_KEY_PEM="-----BEGIN OPENSSH PRIVATE KEY-----\n...\n-----END OPENSSH PRIVATE KEY-----"
DO_SSH_PRIVATE_KEY_PATH=/etc/revaid-mcp/ssh_key.pem
# Comma-separated hard allowlist. Deny-all if empty.
DO_SSH_ALLOWED_HOSTS=
# Path to known_hosts file for strict host-key verification.
DO_SSH_KNOWN_HOSTS_PATH=/etc/revaid-mcp/known_hosts
# Trust-on-first-use (skip known_hosts check). Use ONLY for bootstrap.
# DO_SSH_TOFU=false
